<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
 <SelectDialog
    id="materialDialog"
    title="Seleziona materiale"
    items="{
        path: '/ZMF_IMD_MATERIAL_DESC'
    }"
    liveChange=".onMaterialSearch"
    search=".onMaterialSearch"
    confirm=".onMaterialSelect"
    cancel=".onCloseMaterialListDialog">
    <StandardListItem
        title="{matnr}"
        description="{maktg}"
        type="Active" />
 </SelectDialog>
</core:FragmentDefinition>