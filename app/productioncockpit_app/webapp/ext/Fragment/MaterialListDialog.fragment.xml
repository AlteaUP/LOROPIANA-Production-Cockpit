<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="MaterialListDialog"
        title="Elenco Materiali"
        contentWidth="50%"
        contentHeight="50%"
        resizable="true"
        draggable="true"
        icon="sap-icon://it-host">
        <content>
            <VBox id="MaterialListVBox" width="100%">
                <SearchField
                    id="MaterialSearchField"
                    width="100%"
                    liveChange=".onMaterialSearch"/>
                <Table
                    id="MaterialTable"
                    width="100%"
                    items="{
                        path: '/ZMF_IMD_MATERIAL_DESC',
                        parameters: { $select: 'maktx,maktg,matnr' }
                    }"
                    itemPress=".onMaterialSelect">
                    <columns>
                        <Column>
                            <Text text="{i18n>material}"/>
                        </Column>
                        <Column>
                            <Text text="{i18n>materialDescription}"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Active">
                            <cells>
                                <Text text="{matnr}"/>
                                <Text text="{maktg}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <beginButton>
            <Button
                id="MaterialListDialogCloseButton"
                text="{i18n>closePopUp}"
                press=".onCloseMaterialListDialog"/>
        </beginButton>
    </Dialog>
</core:FragmentDefinition>